# ── Bot ───────────────────────────────────────────────────────────────────────
BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=your_webhook_secret_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://testova:password@localhost:5432/testova_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Gemini cost tracking (read-only /usage). Prices are USD per 1M tokens.
GEMINI_PRICE_IN_PER_M=0.30
GEMINI_PRICE_OUT_PER_M=2.50
UZS_PER_USD=12000

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage

# S3-compatible (set STORAGE_TYPE=s3 to enable)
S3_BUCKET=testova-files
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_REGION=us-east-1

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50

# ── Access control ─────────────────────────────────────────────────────────────
# Telegram IDs auto-promoted to admin on /start (comma-separated).
ADMIN_IDS=123456789,987654321
# Admin handle shown in the blocked/expired message (WITHOUT the leading @).
ADMIN_USERNAME=your_admin_username
# Fresh-user trial applied on first /start: window in days + free full cycles.
TRIAL_DAYS=30
TRIAL_USES=1

# ── Subscription Limits ───────────────────────────────────────────────────────
FREE_DAILY_PROJECTS=3
PRO_DAILY_PROJECTS=50
CENTER_DAILY_PROJECTS=500

# ── Admin API ─────────────────────────────────────────────────────────────────
ADMIN_API_SECRET=your_admin_api_secret
